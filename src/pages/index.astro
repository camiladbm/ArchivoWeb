---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const episodios = await getCollection('podcast');
const epSorted = episodios.sort((a, b) => b.data.numeroEpisodio - a.data.numeroEpisodio);

const articulos = await getCollection('articulos');
const artSorted = articulos.sort(
  (a, b) => b.data.fechaPublicacion.valueOf() - a.data.fechaPublicacion.valueOf()
);
const previewArts = artSorted.slice(0, 3);

function tagColor(tags: string[]): string {
  const tag = (tags[0] ?? '').toLowerCase();
  if (['economía','política monetaria','extractivismo'].some(t => tag.includes(t))) return 'eco';
  if (['política','instituciones','cono sur'].some(t => tag.includes(t))) return 'pol';
  if (['internacional','andes'].some(t => tag.includes(t))) return 'int';
  return 'cul';
}

---

<BaseLayout activeNav="inicio">
<main>

<!-- ============================================================
     HERO — title left, draggable collage right
     ============================================================ -->
<section class="hero" id="inicio">
  <div class="container hero-inner">

    <!-- left column -->
    <div class="hero-left">
      <div class="hero-eye">
        <span class="num">N.º 027</span>
        <span>· Expediente abierto</span>
      </div>

      <h1>IMPULSANDO<br />LA ACADEMIA EN<br /><em>LATINOAMÉRICA</em></h1>

      <p class="hero-subtitle">
        El archivo estudiantil que hace legible, debatible y nuestro
        el pensamiento económico y político de la región.
      </p>

      <div class="hero-meta">
        <div class="hero-meta-item">
          <span class="hero-meta-key">Comunidad</span>
          <span class="hero-meta-val">12 universidades</span>
        </div>
        <div class="hero-meta-item">
          <span class="hero-meta-key">Próxima entrega</span>
          <span class="hero-meta-val">Viernes · El Índice</span>
        </div>
      </div>
    </div>

    <!-- right column: draggable collage -->
    <div class="collage" id="collage">
      <figure class="col-item col-news" data-z="1">
        <img src="/assets/collage-newspaper.png" alt="Portada de la revista Archivo, agosto 1962" />
      </figure>
      <figure class="col-item col-street" data-z="2">
        <img src="/assets/collage-street.png" alt="Plaza latinoamericana — fotografía sepia de archivo" />
        <figcaption class="col-caption">Plaza · s/f</figcaption>
      </figure>
      <figure class="col-item col-note" data-z="3">
        <img src="/assets/collage-typewriter.png" alt="Página mecanografiada — fragmento sobre las promesas del progreso en América Latina" />
      </figure>
      <figure class="col-item col-informe" data-z="4">
        <img src="/assets/collage-informe.png" alt="Nota manuscrita — Informe importante, archivar en caja Nº 3" />
      </figure>
      <figure class="col-item col-card" data-z="5">
        <img src="/assets/collage-library-card.png" alt="Ficha bibliográfica — Banco Interamericano de Desarrollo, 1967" />
      </figure>
      <figure class="col-item col-map" data-z="6">
        <img src="/assets/collage-map.png" alt="Mapa de América del Sur — cartografía vintage sobre pergamino" />
      </figure>
      <figure class="col-item col-stamp" data-z="7">
        <img src="/assets/collage-biblioteca.png" alt="Sello — Archivo Nacional, Biblioteca, División de Documentación" />
      </figure>
    </div>

  </div>
</section>

<!-- ============================================================
     PREVIEW · PUBLICACIONES
     ============================================================ -->
<section class="section preview-section" id="publicaciones" style="background: var(--archivo-cream);">
  <div class="container">
    <div class="section-marker">
      <span><span class="num">01</span> · Publicaciones · Carpeta abierta</span>
      <a class="link" href="/publicaciones">Ver el expediente completo →</a>
    </div>

    <div class="preview-head">
      <h2 class="section-title">LO QUE ESTAMOS ESCRIBIENDO</h2>
    </div>

    <div class="exp-grid" style="margin-top: 56px;">
      {previewArts.map((art, i) => (
        <a class="exp-card" href={`/publicaciones/${art.slug}`}>
          <div class="exp-tab">
            <span class={`tag ${tagColor(art.data.tags)}`}>{art.data.tags[0]}</span>
            <span class="exp-ref">
              <strong>Exp. {String(artSorted.length - i).padStart(3, '0')}</strong>
            </span>
          </div>
          <div class="exp-body">
            <span class="exp-code">
              {art.data.universidad?.split(' ').slice(-2).join(' ')}<br />
              {art.data.fechaPublicacion.toLocaleDateString('es-ES', { month: 'long', year: 'numeric' })}
            </span>
            <h3 class="exp-title">{art.data.titulo}</h3>
            <p class="exp-deck">{art.data.resumen}</p>
            <div class="exp-meta">
              <span class="exp-author">{art.data.autor}</span>
              {art.data.tiempoLectura && <span class="exp-length">{art.data.tiempoLectura} min</span>}
              <span class="exp-uni">{art.data.universidad ?? ''}</span>
            </div>
          </div>
          <div class="exp-cta">
            <span class="leer">Leer <span class="leer-arrow">→</span></span>
            <span class="stamp">Investigación</span>
          </div>
        </a>
      ))}
    </div>

    <div class="preview-foot">
      <a class="btn btn-ghost" href="/publicaciones">
        Ver {artSorted.length > 3 ? `las ${artSorted.length}` : 'todas las'} publicaciones
      </a>
    </div>
  </div>
</section>

<!-- ============================================================
     PREVIEW · PODCAST
     ============================================================ -->
<section class="section preview-section preview-section--alt" id="podcast" style="background: var(--archivo-cream-deep);">
  <div class="container">
    <div class="section-marker">
      <span><span class="num">02</span> · El Podcast · Estudio</span>
      <a class="link" href="/podcast">Catálogo completo →</a>
    </div>

    <div class="preview-head">
      <h2 class="section-title">Archivo <em style="font-style:italic; font-weight:300; color:var(--archivo-ochre);">Abierto</em></h2>
      <p class="section-deck">
        Entrevistas largas con economistas, politólogos y pensadores que están escribiendo la región hoy.
      </p>
    </div>

    <div class="exp-grid" style="margin-top: 56px;">
      {epSorted.slice(0, 3).map(ep => (
        <div class="pod-card">
          <span class="pod-card-wm" aria-hidden="true">
            {String(ep.data.numeroEpisodio).padStart(3, '0')}
          </span>

          <header class="pod-card-head">
            {ep.data.tags?.[0] && (
              <span class={`tag pod-tag ${tagColor(ep.data.tags ?? [])}`}>{ep.data.tags[0]}</span>
            )}
            <span class="pod-card-ep">Ep. {String(ep.data.numeroEpisodio).padStart(3, '0')}</span>
          </header>

          <div class="pod-card-body">
            <h3 class="pod-card-title">{ep.data.titulo}</h3>
            {ep.data.invitado && (
              <p class="pod-card-guest">{ep.data.invitado.split('—')[0].trim()}</p>
            )}
            {ep.data.duracion && (
              <span class="pod-card-dur">{ep.data.duracion}</span>
            )}
          </div>

          <div class="pod-card-actions">
            {ep.data.linkYoutube && (
              <a class="pod-card-btn pod-card-btn--yt" href={ep.data.linkYoutube} target="_blank" rel="noopener">
                ▶&nbsp;YouTube
              </a>
            )}
            {ep.data.linkSpotify && (
              <a class="pod-card-btn pod-card-btn--sp" href={ep.data.linkSpotify} target="_blank" rel="noopener">
                ♪&nbsp;Spotify
              </a>
            )}
            {!ep.data.linkYoutube && !ep.data.linkSpotify && (
              <span class="pod-card-coming">· Próximamente ·</span>
            )}
          </div>
        </div>
      ))}
    </div>

    <div class="preview-foot">
      <a class="btn btn-ghost" href="/podcast">Ver todos los episodios</a>
    </div>
  </div>
</section>


</main>
</BaseLayout>

<style>
/* ── Podcast preview card ── */
.pod-card {
  position: relative;
  display: flex;
  flex-direction: column;
  background: var(--archivo-green);
  overflow: hidden;
  isolation: isolate;
  box-shadow:
    0 1px 0 rgba(16, 97, 88, 0.2),
    0 18px 36px -14px rgba(16, 97, 88, 0.45);
  transition: transform 240ms var(--ease-quiet),
              box-shadow 240ms var(--ease-quiet);
}
.pod-card::before {
  content: "";
  position: absolute; inset: 0;
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='240' height='240'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='2' stitchTiles='stitch'/><feColorMatrix values='0 0 0 0 0.95 0 0 0 0 0.9 0 0 0 0 0.7 0 0 0 0.45 0'/></filter><rect width='100%25' height='100%25' filter='url(%23n)' opacity='0.28'/></svg>");
  mix-blend-mode: screen;
  opacity: 0.6;
  pointer-events: none;
  z-index: 0;
}
.pod-card:hover {
  transform: translateY(-5px) rotate(0.15deg);
  box-shadow:
    0 2px 0 rgba(16, 97, 88, 0.25),
    0 36px 52px -18px rgba(16, 97, 88, 0.6);
}

/* watermark episode number */
.pod-card-wm {
  position: absolute;
  bottom: -12px; right: -6px;
  font-family: var(--font-display);
  font-weight: 800;
  font-size: clamp(5.5rem, 10vw, 8.5rem);
  line-height: 1;
  letter-spacing: -0.04em;
  color: rgba(250, 242, 233, 0.07);
  user-select: none;
  pointer-events: none;
  z-index: 0;
}

/* header bar */
.pod-card-head {
  position: relative; z-index: 1;
  display: flex; align-items: center;
  justify-content: space-between; gap: 12px;
  padding: 14px 20px;
  background: rgba(0, 0, 0, 0.18);
  border-bottom: 1px solid rgba(250, 242, 233, 0.1);
}
.pod-tag {
  border-color: rgba(250, 242, 233, 0.35) !important;
  color: var(--archivo-ochre) !important;
  font-size: 10px !important;
  padding: 3px 9px !important;
}
.pod-tag::before { background: var(--archivo-ochre) !important; }
.pod-card-ep {
  font-family: var(--font-display);
  font-style: italic; font-weight: 300;
  font-size: 11px; letter-spacing: 0.16em;
  text-transform: uppercase;
  color: rgba(250, 242, 233, 0.45);
}

/* body */
.pod-card-body {
  position: relative; z-index: 1;
  padding: 28px 24px 20px;
  display: flex; flex-direction: column;
  gap: 10px; flex: 1;
}
.pod-card-title {
  margin: 0;
  font-family: var(--font-display);
  font-weight: 800; text-transform: uppercase;
  font-size: clamp(1.25rem, 1.7vw, 1.5rem);
  line-height: 1.05; letter-spacing: -0.025em;
  color: var(--archivo-cream);
  text-wrap: balance;
}
.pod-card-guest {
  margin: 4px 0 0;
  font-family: var(--font-display);
  font-style: italic; font-weight: 300;
  font-size: 14px; letter-spacing: 0.02em;
  color: rgba(250, 242, 233, 0.7);
}
.pod-card-dur {
  display: inline-block;
  margin-top: 6px;
  font-family: var(--font-display);
  font-style: italic; font-weight: 300;
  font-size: 11px; letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--archivo-ochre);
  opacity: 0.85;
}

/* actions */
.pod-card-actions {
  position: relative; z-index: 1;
  display: flex; gap: 8px;
  padding: 16px 20px 20px;
  border-top: 1px solid rgba(250, 242, 233, 0.1);
}
.pod-card-btn {
  flex: 1;
  display: inline-flex; align-items: center; justify-content: center;
  font-family: var(--font-display);
  font-weight: 700; font-size: 11px;
  letter-spacing: 0.12em; text-transform: uppercase;
  text-decoration: none; padding: 10px 8px;
  transition: background 160ms, color 160ms, border-color 160ms;
}
.pod-card-btn--yt {
  background: var(--archivo-ochre);
  color: var(--archivo-brown);
}
.pod-card-btn--yt:hover { background: #e8b94a; }
.pod-card-btn--sp {
  background: transparent;
  color: var(--archivo-cream);
  border: 1.5px solid rgba(250, 242, 233, 0.35);
}
.pod-card-btn--sp:hover {
  border-color: var(--archivo-cream);
  background: rgba(250, 242, 233, 0.08);
}
.pod-card-coming {
  font-family: var(--font-display);
  font-style: italic; font-weight: 300;
  font-size: 12px; letter-spacing: 0.14em;
  color: rgba(250, 242, 233, 0.3);
}
</style>

<script>
  /* Draggable collage */
  (function setupDrag() {
    const collage = document.getElementById('collage');
    if (!collage) return;
    const items = Array.from(document.querySelectorAll<HTMLElement>('.col-item'));
    let zCounter = 10;

    items.forEach(item => {
      const cR = collage.getBoundingClientRect();
      const iR = item.getBoundingClientRect();
      item.style.left   = (iR.left - cR.left) + 'px';
      item.style.top    = (iR.top  - cR.top)  + 'px';
      item.style.right  = 'auto';
      item.style.bottom = 'auto';
      item.style.setProperty('--tx', '0px');
      item.style.setProperty('--ty', '0px');
      item.addEventListener('pointerdown', onDown);
    });

    function onDown(e: PointerEvent) {
      const item = e.currentTarget as HTMLElement;
      const collageRect = collage.getBoundingClientRect();
      const itemRect = item.getBoundingClientRect();
      zCounter += 1;
      item.style.zIndex = String(zCounter);
      item.classList.add('is-dragging');
      item.setPointerCapture(e.pointerId);

      const offsetX = e.clientX - itemRect.left;
      const offsetY = e.clientY - itemRect.top;
      const baseLeft = parseFloat(item.style.left) || 0;
      const baseTop  = parseFloat(item.style.top)  || 0;

      function onMove(ev: PointerEvent) {
        let nextLeft = ev.clientX - collageRect.left - offsetX;
        let nextTop  = ev.clientY - collageRect.top  - offsetY;
        const slop = 100;
        const w = item.offsetWidth, h = item.offsetHeight;
        nextLeft = Math.max(-slop, Math.min(collageRect.width  - w + slop, nextLeft));
        nextTop  = Math.max(-slop, Math.min(collageRect.height - h + slop, nextTop));
        item.style.setProperty('--tx', (nextLeft - baseLeft) + 'px');
        item.style.setProperty('--ty', (nextTop  - baseTop)  + 'px');
      }
      function onUp() {
        item.classList.remove('is-dragging');
        item.removeEventListener('pointermove', onMove);
        item.removeEventListener('pointerup', onUp);
        item.removeEventListener('pointercancel', onUp);
        const cs = getComputedStyle(item);
        const currentBase = parseFloat(cs.getPropertyValue('--base-rot')) || 0;
        const wobble = (Math.random() * 4 - 2);
        item.style.setProperty('--base-rot', currentBase + wobble + 'deg');
      }
      item.addEventListener('pointermove', onMove);
      item.addEventListener('pointerup', onUp);
      item.addEventListener('pointercancel', onUp);
    }
  })();

</script>

