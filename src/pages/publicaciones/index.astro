---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const articulos = await getCollection('articulos');
const sorted = articulos.sort(
  (a, b) => b.data.fechaPublicacion.valueOf() - a.data.fechaPublicacion.valueOf()
);

function formatFecha(date: Date): string {
  return date.toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' });
}

function tagColor(tag: string): string {
  const eco = ['economía', 'extractivismo', 'política monetaria'];
  const pol = ['política', 'instituciones', 'cono sur'];
  const int = ['internacional', 'andes'];
  if (eco.some(t => tag.toLowerCase().includes(t))) return 'eco';
  if (pol.some(t => tag.toLowerCase().includes(t))) return 'pol';
  if (int.some(t => tag.toLowerCase().includes(t))) return 'int';
  return 'cul';
}
---

<BaseLayout
  title="Publicaciones — Archivo"
  description="Artículos de análisis económico y político latinoamericano escritos por estudiantes de la región."
  activeNav="publicaciones"
>

<main class="publicaciones-main">

  <!-- PAGE HEADER -->
  <section class="pub-header section">
    <div class="container">
      <div class="section-marker">
        <span>Archivo <span class="num">·</span> Publicaciones académicas</span>
      </div>
      <h1 class="section-title" style="margin-top: 28px;">
        Las publicaciones de<br /><em style="font-style:italic; font-weight:300; color:var(--archivo-ochre);">nuestros integrantes.</em>
      </h1>
      <p class="section-deck" style="margin-top: 18px; max-width: 52ch;">
        Artículos de análisis económico y político latinoamericano escritos por estudiantes de la región.
      </p>
      <div class="pub-header-meta">
        <span class="pub-count">{sorted.length} publicaciones</span>
        <span class="pub-sep">·</span>
        <span class="pub-count-label">ordenadas del más reciente al más antiguo</span>
      </div>
    </div>
  </section>

  <!-- ARTICLE GRID -->
  <section class="section" style="background: #faf2e9;">
    <div class="container">
      <div class="exp-grid">
        {sorted.map((art, i) => {
          const color = tagColor(art.data.tags[0] ?? '');
          const num = String(sorted.length - i).padStart(3, '0');
          return (
            <a class="exp-card" href={`/publicaciones/${art.slug}`}>
              <div class="exp-tab">
                <span class={`tag ${color}`}>{art.data.tags[0]}</span>
                <span class="exp-ref">
                  <strong>Exp. {num}</strong>
                </span>
              </div>

              <div class="exp-body">
                <span class="exp-code">
                  {art.data.universidad ? art.data.universidad.split(' ').slice(-2).join(' ') : ''}
                </span>
                <h2 class="exp-title">{art.data.titulo}</h2>
                <p class="exp-deck">{art.data.resumen}</p>

                <div class="exp-meta">
                  <span class="exp-author">{art.data.autor}</span>
                  {art.data.tiempoLectura && (
                    <span class="exp-length">{art.data.tiempoLectura} min</span>
                  )}
                  <span class="exp-uni">{art.data.universidad ?? ''}</span>
                </div>
              </div>

              <div class="exp-cta">
                <span class="leer">
                  Leer artículo <span class="leer-arrow">→</span>
                </span>
                <span class="stamp">{formatFecha(art.data.fechaPublicacion)}</span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

</main>

</BaseLayout>

<style>
.pub-header-meta {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-top: 28px;
  padding-top: 18px;
  border-top: 1px solid var(--archivo-grey-green);
  font-family: var(--font-display);
  font-style: italic;
  font-weight: 300;
  font-size: 13px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--archivo-grey-green);
}
.pub-count { font-style: normal; font-weight: 700; color: var(--archivo-brown); }
</style>
